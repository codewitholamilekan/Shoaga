stats = {"wins": 0, "losses": 0}

def get_stats_text():
    total = stats["wins"] + stats["losses"]
    win_rate = (stats["wins"] / total * 100) if total > 0 else 0
    return (
        f"📊 *Trading Stats:*\n"
        f"✅ Wins: {stats['wins']}\n"
        f"❌ Losses: {stats['losses']}\n"
